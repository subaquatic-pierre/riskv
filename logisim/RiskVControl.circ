      <a name="text" val="MemByteSel[1] = func3[0]"/>
    </comp>
    <comp lib="9" loc="(2040,1570)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="halign" val="left"/>
      <a name="text" val="MemByteSel[2] = func3[1]"/>
    </comp>
    <comp lib="9" loc="(2095,2155)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Breakpoint trap flag."/>
    </comp>
    <comp lib="9" loc="(2125,975)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="halign" val="left"/>
      <a name="text" val="Sent directly to ALUController"/>
    </comp>
    <comp lib="9" loc="(2160,515)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ImmSel[2] = JAL"/>
    </comp>
    <comp lib="9" loc="(2165,1355)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Enables Data Memory read operations."/>
    </comp>
    <comp lib="9" loc="(2175,1415)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Enables Data Memory write operations."/>
    </comp>
    <comp lib="9" loc="(2180,1015)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ALUSel[1] = funct3[1]"/>
    </comp>
    <comp lib="9" loc="(2180,1030)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ALUSel[2] = funct3[2]"/>
    </comp>
    <comp lib="9" loc="(2180,995)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ALUSel[0] = funct3[0]"/>
    </comp>
    <comp lib="9" loc="(2185,675)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Selects ALU operand A"/>
    </comp>
    <comp lib="9" loc="(2195,2095)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Selects the writeback source (ALU result vs. Memory read data)."/>
    </comp>
    <comp lib="9" loc="(2195,695)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ASel = AUIPC OR Branch OR JAL"/>
    </comp>
    <comp lib="9" loc="(2200,1735)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Master write-enable for the register file."/>
    </comp>
    <comp lib="9" loc="(2210,1835)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(2 bit): Selects the writeback source (ALU result vs. Memory read data)."/>
    </comp>
    <comp lib="9" loc="(2215,450)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(3bit):  Send to ImmGen Sel input"/>
    </comp>
    <comp lib="9" loc="(2220,475)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ImmSel[0] = Store OR LUI OR AUIPC"/>
    </comp>
    <comp lib="9" loc="(2225,495)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ImmSel[1] = Branch OR LUI OR AUIPC"/>
    </comp>
    <comp lib="9" loc="(2260,1050)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ALUSel[3] = funct7[5] AND (RType OR IShift_Right)"/>
    </comp>
    <comp lib="9" loc="(2260,1070)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ALUSel[4] = funct7[0] AND (RType OR IShift_Right)"/>
    </comp>
    <comp lib="9" loc="(2265,795)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Selects ALU operand B (Register vs. Immediate)."/>
    </comp>
    <comp lib="9" loc="(2265,820)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="BSel = IType OR Load OR Store OR AUIPC OR JAL OR JALR"/>
    </comp>
    <comp lib="9" loc="(2275,1170)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(4bit): 3 Bit branch selector code sent directly to the BranchControl"/>
    </comp>
    <comp lib="9" loc="(900,1295)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="halign" val="left"/>
      <a name="text" val="NOP = All regsiters are ZERO and func7 is ZERO"/>
    </comp>
