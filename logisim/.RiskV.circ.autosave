    <comp lib="9" loc="(2210,1805)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(2 bit): Selects the writeback source (ALU result vs. Memory read data)."/>
    </comp>
    <comp lib="9" loc="(2215,450)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(3bit):  Send to ImmGen Sel input"/>
    </comp>
    <comp lib="9" loc="(2220,475)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ImmSel[0] = Store OR LUI OR AUIPC"/>
    </comp>
    <comp lib="9" loc="(2225,495)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ImmSel[1] = Branch OR LUI OR AUIPC"/>
    </comp>
    <comp lib="9" loc="(2260,1025)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ALUSel[0] = funct7[5] AND (RType OR IShift_Right)"/>
    </comp>
    <comp lib="9" loc="(2265,795)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Selects ALU operand B (Register vs. Immediate)."/>
    </comp>
    <comp lib="9" loc="(2265,820)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="BSel = IType OR Load OR Store OR AUIPC OR JAL OR JALR"/>
    </comp>
    <comp lib="9" loc="(2270,1515)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(3bit): Bus to control which bytes are active during memory read and write"/>
    </comp>
    <comp lib="9" loc="(2275,1170)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(4bit): 3 Bit branch selector code sent directly to the BranchControl"/>
    </comp>
    <comp lib="9" loc="(2340,990)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(4 bits): Sent directly to ALUSel bus Top 3 bits from funct3 LSB from funct7[5]"/>
    </comp>
    <comp lib="9" loc="(480,1275)" name="Text">
      <a name="halign" val="left"/>
      <a name="text" val="ALUSel0Mode = R_Type OR IShift_Right"/>
    </comp>
    <comp lib="9" loc="(480,1405)" name="Text">
      <a name="halign" val="left"/>
      <a name="text" val="Is_Arithmetic = R_Type OR I_Type"/>
    </comp>
    <comp lib="9" loc="(570,1090)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="Funct3 == 000"/>
    </comp>
    <comp lib="9" loc="(710,905)" name="Text">
      <a name="text" val="SYSTEM_CTL"/>
    </comp>
