    <comp lib="9" loc="(2189,676)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="(1 bit): Selects ALU operand A"/>
    </comp>
    <comp lib="9" loc="(2198,698)" name="Text">
      <a name="font" val="SansSerif plain 12"/>
      <a name="text" val="ASel = AUIPC OR Branch OR JAL"/>
